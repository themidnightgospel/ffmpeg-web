---
import Brand from '@/components/Brand.astro';
import { withBase } from '@/lib/url';

const REPO_URL = 'https://github.com/';
---

<footer class="site">
  <div class="wrap foot-grid">
    <div>
      <div class="foot-brand"><Brand /></div>
      <p>
        Free, open, 100% client-side media tools powered by ffmpeg.wasm. Hosted on GitHub Pages. No
        accounts, no uploads, no tracking.
      </p>
    </div>
    <div>
      <p class="eyebrow">Project</p>
      <ul>
        <li><a href={REPO_URL} target="_blank" rel="noreferrer">Source on GitHub</a></li>
        <li><a href={withBase('/convert/')}>Convert</a></li>
      </ul>
    </div>
    <div>
      <p class="eyebrow">Made in</p>
      <p>Kutaisi, Georgia</p>
    </div>
  </div>
</footer>
