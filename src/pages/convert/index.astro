---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Masthead from '@/components/Masthead.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Converter from '@/components/Converter.tsx';
import { PAIRS } from '@/lib/kb/pairs';
import { webApplicationLd, breadcrumbLd } from '@/lib/seo/jsonld';

const siteUrl = Astro.site?.href ?? 'https://khinkali.cc';

const title = 'Video Converter — Convert Video Free & In-Browser | Khinkali Tool Chain';
const description =
  'Free online video converter. Convert MP4, WebM, MKV, MOV, AVI, and FLV right in your browser — no uploads, no watermarks, completely private.';

const jsonLd = [
  webApplicationLd(siteUrl),
  breadcrumbLd([
    { label: 'Home', url: new URL('/', siteUrl).href },
    { label: 'Convert', url: new URL('/convert/', siteUrl).href },
  ]),
];
---

<BaseLayout title={title} description={description} canonicalPath="/convert/" jsonLd={jsonLd}>
  <Masthead back />

  <section class="tool-head">
    <div class="wrap">
      <Breadcrumbs crumbs={[{ label: 'Convert' }]} />
      <h1>Video Converter</h1>
    </div>
  </section>

  <Converter slug="video-converter" client:visible />

  <section class="wrap convert-index">
    <p class="section-label">All conversions</p>
    <ul class="pairs-grid">
      {PAIRS.map((p) => <li><a href={`/convert/${p.slug}`}>{p.from.name} to {p.to.name}</a></li>)}
    </ul>
  </section>

  <Footer />
</BaseLayout>
