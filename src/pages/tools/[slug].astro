---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Masthead from '@/components/Masthead.astro';
import Footer from '@/components/Footer.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import { TOOLS, getToolMeta, toolNumber } from '@/data/tools';
import { breadcrumbLd } from '@/lib/seo/jsonld';

export function getStaticPaths() {
  // The video converter lives at /convert/; every other tool gets a /tools/ page.
  return TOOLS.filter((t) => t.slug !== 'video-converter').map((t) => ({
    params: { slug: t.slug },
  }));
}

const { slug } = Astro.params;
const meta = slug ? getToolMeta(slug) : undefined;
if (!slug || !meta) throw new Error(`Unknown tool: ${slug}`);

const siteUrl = Astro.site?.href ?? 'https://ffmpeg.web';
const canonicalPath = `/tools/${slug}`;

const title = `${meta.name} — Free, In-Browser | ffmpeg.web`;
const description = `${meta.desc} Free, private, and 100% in your browser — nothing uploaded.`;

const jsonLd = [
  breadcrumbLd([
    { label: 'Home', url: new URL('/', siteUrl).href },
    { label: meta.name, url: new URL(canonicalPath, siteUrl).href },
  ]),
];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
>
  <Masthead back />

  <section class="tool-head">
    <div class="wrap">
      <Breadcrumbs crumbs={[{ label: 'Tools', href: '/' }, { label: meta.name }]} />
      <p class="idx">{toolNumber(slug)} / {meta.category}</p>
      <h1>{meta.name}</h1>
      <p class="lead">{meta.desc}</p>
    </div>
  </section>

  <section class="wrap coming">
    <p class="section-label">Coming soon</p>
    <p class="lead">
      This tool is specified and on the roadmap. Its spec lives in
      <code>specs/features/{slug}.md</code>.
    </p>
    <p class="note">
      When built, all processing will happen in your browser — nothing uploaded.
    </p>
  </section>

  <Footer />
</BaseLayout>
