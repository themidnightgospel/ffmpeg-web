---
// Self-hosted Inter (required under COEP: require-corp — no cross-origin font CDN).
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/inter/800.css';

// The design system is the single source of styling truth.
import '../../design-system/ffmpeg-web.css';
import '@/styles/app.css';

import Seo from '@/components/Seo.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, canonicalPath, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <Seo title={title} description={description} canonicalPath={canonicalPath} jsonLd={jsonLd} />
    {/* No cross-origin isolation needed: we use the single-threaded ffmpeg core
        (the multithreaded core was unreliable). See docs/tech-stack.md. */}
  </head>
  <body>
    <slot />
  </body>
</html>
