{
  "name": "ffmpeg-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Free, 100% client-side, in-browser media tools powered by ffmpeg.wasm.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "predev": "node scripts/copy-ffmpeg-core.mjs",
    "dev": "astro dev",
    "prebuild": "node scripts/copy-ffmpeg-core.mjs",
    "build": "astro build",
    "preview": "astro preview",
    "serve:dist": "node scripts/serve-dist.mjs",
    "typecheck": "astro check",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,astro}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:matrix": "playwright test conversion-matrix"
  },
  "dependencies": {
    "@astrojs/react": "^3.6.2",
    "@astrojs/sitemap": "^3.2.1",
    "@ffmpeg/core": "^0.12.6",
    "@ffmpeg/core-mt": "^0.12.6",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "@fontsource/inter": "^5.1.0",
    "astro": "^4.15.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@playwright/test": "^1.47.2",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
